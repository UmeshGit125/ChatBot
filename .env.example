# Database
DATABASE_URL=sqlite+aiosqlite:///./mock.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/college_db

# Metabase (alternative to direct DB - set USE_METABASE=true to enable)
USE_METABASE=false
METABASE_URL=https://metabase.yourcompany.com
METABASE_USERNAME=your-email@company.com
METABASE_PASSWORD=your-metabase-password
METABASE_DATABASE_ID=1

# LLM Provider
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: OpenAI (for future swap)
# OPENAI_API_KEY=your-openai-api-key-here

# Application
APP_ENV=development
LOG_LEVEL=INFO
QUERY_LOG_FILE=query_logs.json

# Week definition: "calendar" (Mon-Sun) or "rolling7"
WEEK_DEFINITION=calendar

# Rate limiting
RATE_LIMIT_PER_MINUTE=10

# Query timeout in seconds
QUERY_TIMEOUT_SECONDS=10

# Backend URL (for Streamlit)
BACKEND_URL=http://localhost:8000
